{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://praetor.dev/schema/praetor.spec.schema.json",
  "title": "Praetor Spec",
  "description": "Declarative safety spec for an onchain agent wallet. One artifact, two compilation targets: on-chain guard config + off-chain engine checks. Fail-closed: anything not explicitly permitted is denied.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "account",
    "chain"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Spec format version. Bump on breaking schema changes."
    },
    "account": {
      "$ref": "#/$defs/address",
      "description": "The agent smart-account this spec governs."
    },
    "chain": {
      "type": "string",
      "enum": [
        "base",
        "base-sepolia"
      ],
      "description": "Target chain. One spec governs one account on one chain."
    },
    "spec_hash": {
      "type": "string",
      "pattern": "^(auto|0x[0-9a-fA-F]{64})$",
      "description": "keccak256 of the canonicalized spec, committed on-chain. 'auto' = compute at compile time."
    },
    "allowlist": {
      "type": "array",
      "description": "ON-CHAIN ENFORCED. Permitted (target, selector) pairs. Empty/absent => no calls permitted (fail-closed).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "address",
          "functions"
        ],
        "properties": {
          "protocol": {
            "type": "string",
            "description": "Human label only; not enforced."
          },
          "address": {
            "$ref": "#/$defs/address"
          },
          "functions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "description": "Permitted function names/selectors on this target."
          }
        }
      }
    },
    "recipients": {
      "type": "object",
      "additionalProperties": false,
      "description": "ON-CHAIN ENFORCED. Allowlisted recipients for transfer-class calls (anti-spoofing).",
      "required": [
        "allow"
      ],
      "properties": {
        "allow": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/address"
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "description": "ON-CHAIN ENFORCED. USD-denominated caps + slippage bound.",
      "required": [
        "max_slippage_bps"
      ],
      "properties": {
        "per_tx_usd": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "rolling_24h_usd": {
          "$ref": "#/$defs/nonNegativeNumber"
        },
        "max_slippage_bps": {
          "$ref": "#/$defs/bps"
        }
      }
    },
    "rate": {
      "type": "object",
      "additionalProperties": false,
      "description": "ON-CHAIN ENFORCED. Rolling per-hour transaction count cap.",
      "required": [
        "max_tx_per_hour"
      ],
      "properties": {
        "max_tx_per_hour": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "circuit_breaker": {
      "type": "object",
      "additionalProperties": false,
      "description": "Global kill switch trip threshold. Engine trips it; on-chain guard enforces the freeze.",
      "required": [
        "halt_on_drawdown_pct"
      ],
      "properties": {
        "halt_on_drawdown_pct": {
          "$ref": "#/$defs/pct"
        }
      }
    },
    "invariants": {
      "type": "object",
      "additionalProperties": false,
      "description": "OFF-CHAIN ENFORCED (simulation-backed). The differentiated checks. Intentional coupling: enabling this block requires the oracle-deviation wedge (oracle_deviation_bps) and a reference feed; drawdown/exposure/token-safety are optional add-ons.",
      "required": [
        "oracle_deviation_bps",
        "reference"
      ],
      "properties": {
        "oracle_deviation_bps": {
          "$ref": "#/$defs/bps",
          "description": "Block if |realized exec price - reference price| exceeds this, in bps."
        },
        "reference": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "max_staleness_sec"
          ],
          "properties": {
            "source": {
              "type": "string",
              "enum": [
                "chainlink"
              ]
            },
            "max_staleness_sec": {
              "type": "integer",
              "minimum": 0,
              "description": "A reference round older than this (or answeredInRound < roundId) => BLOCK, not pass."
            }
          }
        },
        "max_drawdown_pct": {
          "$ref": "#/$defs/pct",
          "description": "Block if post-trade equity < (1 - this/100) * high-water mark."
        },
        "max_exposure_pct": {
          "type": "object",
          "description": "Optional per-asset exposure caps, keyed by token symbol. Value = max % of post-trade equity.",
          "additionalProperties": {
            "$ref": "#/$defs/pct"
          }
        },
        "token_safety": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "block_honeypot": {
              "type": "boolean"
            },
            "require_mint_renounced": {
              "type": "boolean"
            },
            "max_transfer_tax_bps": {
              "$ref": "#/$defs/bps"
            },
            "block_blacklistable": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "on_block": {
      "type": "object",
      "additionalProperties": false,
      "description": "Behavior when a check fails.",
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "feedback",
            "halt"
          ]
        },
        "log": {
          "type": "boolean"
        },
        "feedback_verbosity": {
          "type": "string",
          "enum": [
            "minimal",
            "structured"
          ]
        }
      }
    }
  },
  "$defs": {
    "address": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$",
      "description": "20-byte EVM address."
    },
    "nonNegativeNumber": {
      "type": "number",
      "minimum": 0
    },
    "bps": {
      "type": "number",
      "minimum": 0,
      "maximum": 10000,
      "description": "Basis points, 0..10000 (= 0%..100%)."
    },
    "pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Percent, 0..100."
    }
  }
}
